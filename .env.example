# ============================================================
# TUNTUN — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secret API keys.
# ============================================================

# ── Required ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# ── Default model (fallback for everything not explicitly set)
OPENAI_MODEL=gpt-4o-mini

# ── Multi-model routing
# ROUTER   — дешёвая модель для классификации intent (быстро и дёшево)
OPENAI_MODEL_ROUTER=gpt-4o-mini

# CHAT     — умная модель для разговора, советов, объяснений
OPENAI_MODEL_CHAT=gpt-4o-mini

# REASONING — сильная модель для планирования, аналитики, неоднозначных запросов
OPENAI_MODEL_REASONING=gpt-4o

# VISION   — анализ фото, чеков, документов, скриншотов (пусто = Vision отключён)
OPENAI_MODEL_VISION=gpt-4o-mini

# TRANSCRIBE — голосовые → текст
OPENAI_MODEL_TRANSCRIBE=whisper-1

# EMBEDDINGS — semantic search (зарезервировано для V2, пока не используется)
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-small

# ── Database & paths
DATABASE_PATH=tuntun.db

# ── Timezone (pytz format)
TIMEZONE=Europe/Warsaw

# ── Access control (comma-separated Telegram user IDs)
ADMIN_TELEGRAM_IDS=

# ── Auto-update (used by auto_update.bat)
GIT_BRANCH=main
AUTO_UPDATE_ENABLED=true
AUTO_UPDATE_INTERVAL_MINUTES=2
